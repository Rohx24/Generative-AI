<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cancer Awareness & Support | Jaurat Care</title>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0f172a;
      --bg-soft: #111c34;
      --card: rgba(255, 255, 255, 0.06);
      --text: #e8edf7;
      --muted: #b9c4dd;
      --accent: #f9637c;
      --accent-2: #5ae2c1;
      --outline: rgba(255, 255, 255, 0.12);
      --shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
      --radius-lg: 24px;
      --radius: 14px;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: 'Manrope', system-ui, -apple-system, sans-serif;
      background: radial-gradient(120% 120% at 20% 20%, rgba(90, 226, 193, 0.07), transparent 50%),
                  radial-gradient(80% 90% at 80% 0%, rgba(249, 99, 124, 0.08), transparent 45%),
                  var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.6;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 10;
      backdrop-filter: blur(12px);
      background: linear-gradient(90deg, rgba(15, 23, 42, 0.9), rgba(17, 28, 52, 0.85));
      border-bottom: 1px solid var(--outline);
    }

    .nav {
      max-width: 1100px;
      margin: 0 auto;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 700;
      letter-spacing: 0.5px;
      text-decoration: none;
      color: var(--text);
    }

    .brand-mark {
      width: 36px;
      height: 36px;
      border-radius: 12px;
      background: linear-gradient(145deg, var(--accent), #ff9db1);
      display: grid;
      place-items: center;
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      color: #0f0f18;
      box-shadow: var(--shadow);
    }

    .nav-links {
      display: flex;
      gap: 16px;
      align-items: center;
    }

    .nav-links a {
      color: var(--muted);
      text-decoration: none;
      font-weight: 600;
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid transparent;
      transition: 0.2s ease;
    }

    .nav-links a:hover {
      color: var(--text);
      border-color: var(--outline);
      background: rgba(255, 255, 255, 0.05);
    }

    main {
      max-width: 1100px;
      margin: 0 auto;
      padding: 32px 20px 60px;
    }

    .hero {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 32px;
      align-items: center;
      padding: 32px;
      border-radius: var(--radius-lg);
      background: linear-gradient(135deg, rgba(90, 226, 193, 0.1), rgba(249, 99, 124, 0.14)), var(--bg-soft);
      border: 1px solid var(--outline);
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: 0;
      background: url('https://images.unsplash.com/photo-1526256262350-7da7584cf5eb?auto=format&fit=crop&w=1200&q=80') center/cover;
      opacity: 0.18;
      mix-blend-mode: screen;
      pointer-events: none;
    }

    .hero-content { position: relative; z-index: 1; }

    .eyebrow {
      text-transform: uppercase;
      letter-spacing: 2px;
      font-size: 12px;
      color: var(--accent-2);
      font-weight: 700;
      margin-bottom: 10px;
    }

    h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(32px, 5vw, 48px);
      line-height: 1.2;
      margin: 0 0 14px;
    }

    p { margin: 0 0 16px; color: var(--muted); }

    .actions { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 14px; }

    .button {
      appearance: none;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 12px 18px;
      font-weight: 700;
      cursor: pointer;
      transition: 0.2s ease;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: #0f0f18;
      background: linear-gradient(135deg, var(--accent), #ff8da6);
      box-shadow: 0 15px 35px rgba(249, 99, 124, 0.25);
    }

    .button.secondary { background: transparent; color: var(--text); border-color: var(--outline); box-shadow: none; }
    .button:hover { transform: translateY(-2px); box-shadow: 0 18px 40px rgba(249, 99, 124, 0.3); }
    .button.secondary:hover { border-color: var(--accent); color: #fff; }

    .hero-card {
      position: relative;
      padding: 24px;
      border-radius: var(--radius);
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(6px);
      z-index: 1;
    }

    .hero-card h3 { margin: 0 0 8px; font-size: 18px; color: #fff; }
    .hero-card p { margin: 0; }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 18px;
      margin: 32px 0;
    }

    .card {
      padding: 20px;
      border-radius: var(--radius);
      background: var(--card);
      border: 1px solid var(--outline);
      box-shadow: var(--shadow);
      transition: transform 0.15s ease, border-color 0.2s ease;
    }

    .card:hover { transform: translateY(-4px); border-color: rgba(90, 226, 193, 0.4); }
    .card h4 { margin: 0 0 8px; color: #fff; font-size: 17px; }

    .section-heading { margin: 40px 0 16px; }
    .section-heading h2 { margin: 6px 0 8px; font-size: clamp(26px, 4vw, 32px); color: #fff; font-family: 'Playfair Display', serif; }

    .quote-section {
      background: linear-gradient(145deg, rgba(90, 226, 193, 0.12), rgba(249, 99, 124, 0.12)), var(--bg-soft);
      border: 1px solid var(--outline);
      border-radius: var(--radius-lg);
      padding: 22px;
      box-shadow: var(--shadow);
    }

    .quote-card {
      border-radius: var(--radius);
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      padding: 18px;
      margin-top: 18px;
      position: relative;
      overflow: hidden;
    }

    .quote-card::before {
      content: "“";
      position: absolute;
      font-family: 'Playfair Display', serif;
      font-size: 120px;
      color: rgba(255, 255, 255, 0.06);
      top: -36px;
      left: 12px;
    }

    .quote-text { font-size: 18px; color: #fff; margin: 0 0 10px; }
    .quote-author { font-weight: 700; color: var(--accent-2); }
    .quote-status { color: var(--muted); font-size: 13px; margin-top: 8px; }

    .quote-controls { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 10px; }

    .input, select {
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid var(--outline);
      border-radius: 10px;
      padding: 12px 14px;
      color: #fff;
      font-weight: 600;
      min-width: 220px;
    }

    form.contact {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      margin-top: 10px;
    }

    textarea { resize: vertical; min-height: 120px; font-family: inherit; }
    .full-row { grid-column: 1 / -1; }

    footer {
      max-width: 1100px;
      margin: 20px auto 40px;
      padding: 12px 20px;
      color: var(--muted);
      text-align: center;
      border-top: 1px solid var(--outline);
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid var(--outline);
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.3px;
    }

    .status { font-size: 13px; color: var(--muted); margin-top: 6px; }

    @media (max-width: 640px) {
      .nav { padding: 12px 16px; }
      .hero { padding: 24px; }
      .quote-controls .button { width: 100%; justify-content: center; }
    }
  </style>
</head>
<body>
  <header>
    <div class="nav">
      <a class="brand" href="#top">
        <span class="brand-mark">JC</span>
        <span>Jaurat Care</span>
      </a>
      <nav class="nav-links">
        <a href="#quotes">Quotes</a>
        <a href="#contact">Contact</a>
        <a href="#support">Support</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <section class="hero">
      <div class="hero-content">
        <div class="eyebrow">Cancer Awareness & Support</div>
        <h1>We stand with every fighter, survivor, and supporter.</h1>
        <p>Access trusted guidance, leave a note for our care team, and lean on daily encouragement crafted for the journey. Your story deserves to be heard.</p>
        <div class="actions">
          <a class="button" href="#contact">Talk to us</a>
          <a class="button secondary" href="#quotes">See live quotes</a>
        </div>
      </div>
      <div class="hero-card">
        <div class="pill">24/7 Listening</div>
        <h3>Share your message, we respond with care.</h3>
        <p>Leave your name, email, and a note. We will follow up with resources tailored to you.</p>
      </div>
    </section>

    <section class="grid" id="support">
      <article class="card">
        <div class="pill" style="background: rgba(249, 99, 124, 0.12); border-color: rgba(249, 99, 124, 0.4); color: #ffb0c2;">Early Awareness</div>
        <h4>Know the signals</h4>
        <p>Learn the early signs, screening timelines, and how to advocate for yourself during appointments.</p>
      </article>
      <article class="card">
        <div class="pill" style="background: rgba(90, 226, 193, 0.12); border-color: rgba(90, 226, 193, 0.4); color: #b5ffee;">Care Network</div>
        <h4>Find your circle</h4>
        <p>Connect with local support groups, survivor mentors, and clinicians who specialize in your needs.</p>
      </article>
      <article class="card">
        <div class="pill" style="background: rgba(255, 194, 103, 0.14); border-color: rgba(255, 194, 103, 0.4); color: #ffe2ad;">Daily Strength</div>
        <h4>Stay encouraged</h4>
        <p>Bookmark this page for live quotes from voices who have walked the path and still choose hope.</p>
      </article>
    </section>

    <section id="quotes" class="quote-section">
      <div class="section-heading">
        <div class="eyebrow">Live Inspiration</div>
        <h2>Real-time quotes, powered by API Ninjas</h2>
        <p>Quotes refresh from our backend—just tap the button anytime you want a new spark.</p>
      </div>

      <div class="quote-controls">
        <button class="button" id="fetchQuote" type="button">Get a new quote</button>
      </div>

      <div class="quote-card" aria-live="polite">
        <p class="quote-text" id="quoteText">Fetching your first quote...</p>
        <div class="quote-author" id="quoteAuthor"></div>
        <div class="quote-status" id="quoteStatus">Requesting from API Ninjas...</div>
      </div>
    </section>

    <section id="contact" class="section-heading">
      <div class="eyebrow">Contact</div>
      <h2>Send a note to our care team</h2>
      <p>We read every message. Share as much as you like—this form stays on your device unless you choose to email it.</p>

      <form class="contact" id="contactForm" novalidate>
        <input class="input" type="text" name="name" id="name" placeholder="Full name" required>
        <input class="input" type="email" name="email" id="email" placeholder="Email address" required>
        <textarea class="input full-row" name="message" id="message" placeholder="Your message, concerns, or story" required></textarea>
        <div class="full-row" style="display: flex; gap: 10px; flex-wrap: wrap; align-items: center;">
          <button class="button" type="submit">Send message</button>
          <div class="status" id="formStatus" role="status" aria-live="polite"></div>
        </div>
      </form>
    </section>
  </main>

  <footer>
    Built for the Cancer Awareness & Support community • © 2024 Jaurat Care
  </footer>

  <script>
    const fetchButton = document.getElementById('fetchQuote');
    const quoteText = document.getElementById('quoteText');
    const quoteAuthor = document.getElementById('quoteAuthor');
    const quoteStatus = document.getElementById('quoteStatus');

    const API_KEY = 'hENAZfqivoy5gFg73PKxAg==lsR43oYAptwlscNu';
    const API_URL = 'https://api.api-ninjas.com/v2/quotes?categories=success,wisdom';

    const fallbackQuotes = [
      { quote: 'Hope is the companion of power and the mother of success.', author: 'Samuel Smiles' },
      { quote: 'Strength grows in the moments when you think you cannot go on but you keep going anyway.', author: 'Unknown' },
      { quote: 'You beat cancer by how you live, why you live, and in the manner in which you live.', author: 'Stuart Scott' },
    ];

    async function loadQuote() {
      quoteStatus.textContent = 'Fetching quote...';
      quoteText.textContent = '...';
      quoteAuthor.textContent = '';

      try {
        const response = await fetch(API_URL, {
          headers: { 'X-Api-Key': API_KEY },
        });

        if (!response.ok) {
          throw new Error('Network response was not ok');
        }

        const data = await response.json();
        const first = data[0];

        if (!first || !first.quote) {
          throw new Error('No quote returned');
        }

        quoteText.textContent = first.quote;
        quoteAuthor.textContent = first.author ? '— ' + first.author : '';
        quoteStatus.textContent = 'Live quote loaded';
      } catch (error) {
        const backup = fallbackQuotes[Math.floor(Math.random() * fallbackQuotes.length)];
        quoteText.textContent = backup.quote;
        quoteAuthor.textContent = '— ' + backup.author;
        quoteStatus.textContent = 'Could not reach API. Showing an offline fallback quote.';
        console.error('Quote fetch error:', error);
      }
    }

    fetchButton.addEventListener('click', loadQuote);
    loadQuote();

    const contactForm = document.getElementById('contactForm');
    const formStatus = document.getElementById('formStatus');
    contactForm.addEventListener('submit', (event) => {
      event.preventDefault();
      const name = document.getElementById('name').value.trim();
      const email = document.getElementById('email').value.trim();
      const message = document.getElementById('message').value.trim();

      if (!name || !email || !message) {
        formStatus.textContent = 'Please fill out all fields.';
        return;
      }

      formStatus.textContent = 'Thank you. Your message is ready to send—we will reply via email.';
      contactForm.reset();
    });
  </script>
</body>
</html>
